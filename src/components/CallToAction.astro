---
import { Icon } from 'astro-icon/components';
---

<section id="contact" class="bg-neutral-950 text-white relative overflow-hidden">
  <div class="absolute inset-0 z-0" id="ctaBg">
    <img
      src="https://images.unsplash.com/photo-1451187580459-43490279c0fa?w=1600&q=80"
      alt=""
      class="w-full h-full object-cover opacity-5 grayscale scale-110"
      id="ctaBgImg"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="relative z-10 max-w-[1400px] mx-auto px-8 py-32">
    <p class="tag-pill mb-8" style="border-color:#404040; color:#737373;">Let&rsquo;s build something</p>
    <h2 class="serif reveal-text" style="font-family:'DM Serif Display',serif; font-size:clamp(4rem, 12vw, 10rem); line-height:0.9; letter-spacing:-0.03em;">
      Say Hello <br /><em>Already</em>
    </h2>
    <div class="mt-16 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <p class="text-base text-neutral-400 max-w-sm leading-relaxed reveal-fade">Have a bold idea or a brand that needs a new voice? Let&rsquo;s talk &mdash; the best work starts with a conversation.</p>
      <a
        href="mailto:hello@orbitstudio.co?subject=New%20Project%20Inquiry"
        class="flex items-center gap-3 bg-white text-neutral-900 rounded-full px-7 py-4 text-sm font-semibold hover:bg-neutral-100 transition-all duration-300 shrink-0 reveal-fade group"
      >
        <div class="flex items-center justify-center w-7 h-7 bg-neutral-900 rounded-full group-hover:bg-neutral-700 transition-colors">
          <Icon name="solar:double-alt-arrow-right-bold-duotone" size={16} class="text-white" />
        </div>
        Work With Me
      </a>
    </div>
  </div>
</section>
