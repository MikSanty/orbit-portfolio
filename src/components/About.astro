---
import { Icon } from 'astro-icon/components';
---

<section id="about" class="max-w-[1400px] mx-auto px-8 py-28 reveal-section">
  <div class="mb-12">
    <span class="tag-pill">About Me</span>
  </div>
  <div class="grid md:grid-cols-12 gap-10 items-start mb-20">
    <div class="md:col-span-7">
      <h2 class="section-title serif reveal-text">I don&rsquo;t just design brands &mdash; I give them a reason to exist.</h2>
    </div>
    <div class="md:col-span-4 md:col-start-9 pt-4">
      <p class="text-base text-neutral-500 leading-relaxed reveal-fade">Every project starts with a single question: what story does this brand need to tell? From there, I build systems that look effortless but run deep &mdash; identities that outlast trends and make people feel something real.</p>
    </div>
  </div>

  <div class="grid md:grid-cols-2 gap-6">
    <div class="relative rounded-3xl overflow-hidden bg-neutral-100 aspect-video group cursor-none img-reveal-wrapper">
      <img
        src="https://images.unsplash.com/photo-1497366216548-37526070297c?w=1600&q=80"
        alt="Studio"
        class="w-full h-full object-cover grayscale img-reveal-inner transition-transform duration-700 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
      <div class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-colors flex items-center justify-center">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center shadow-2xl group-hover:scale-110 transition-transform duration-300">
          <Icon name="solar:play-bold-duotone" size={24} class="text-neutral-900 ml-1" />
        </div>
      </div>
    </div>

    <div class="flex flex-col justify-center gap-0 pl-6">
      <div class="border-b border-neutral-100 pb-10 mb-10">
        <p class="display-num serif reveal-num">+580</p>
        <p class="text-base text-neutral-500 mt-3 leading-relaxed max-w-xs reveal-fade">Projects shipped across brand identity, product design, and creative direction.</p>
      </div>
      <div>
        <p class="display-num serif reveal-num">+240</p>
        <p class="text-base text-neutral-500 mt-3 leading-relaxed max-w-xs reveal-fade">Satisfied clients spanning 34 countries and six continents.</p>
      </div>
    </div>
  </div>
</section>
